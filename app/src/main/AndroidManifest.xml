<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network access for Kaspa node connections -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Push notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Voice messages -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Camera (optional, for sharing images) -->
    <uses-permission android:name="android.permission.CAMERA" />

    <!-- Saving a received photo message to the device gallery. Only needed on API 28 and below —
         API 29+ (Q) scoped storage lets MediaStore inserts succeed without this permission. -->
    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" android:maxSdkVersion="28" />

    <!-- System contacts sync: matching (read) and autocreate (write) shadow contacts -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />
    <uses-permission android:name="android.permission.WRITE_CONTACTS" />

    <!-- Vibration for notification feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Biometric/device-credential prompt guarding the seed phrase and account unlock -->
    <uses-permission android:name="android.permission.USE_BIOMETRIC" />

    <!-- Keeps the message/handshake/payment poll loop alive in the background —
         Android freezes a plain background process's threads within seconds otherwise,
         which silently stopped notifications from firing once the app was backgrounded. -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_DATA_SYNC" />

    <application
        android:name=".KaChatApplication"
        android:allowBackup="false"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.KaChat"
        android:usesCleartextTraffic="true">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:theme="@style/Theme.KaChat">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <service
            android:name=".services.SyncForegroundService"
            android:exported="false"
            android:foregroundServiceType="dataSync" />

        <!-- WorkManager's default auto-init is disabled — KaChatApplication implements
             Configuration.Provider so SyncWorker gets constructed via HiltWorkerFactory
             (see SyncWorker.kt) instead of a no-arg constructor. -->
        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="${applicationId}.androidx-startup"
            android:exported="false"
            tools:node="merge">
            <meta-data
                android:name="androidx.work.WorkManagerInitializer"
                android:value="androidx.startup"
                tools:node="remove" />
        </provider>

        <!-- Lets the chat-history export share a plaintext JSON file from app-private cache via a content:// URI, without granting broad file access. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <!-- FCM Push Notification Service (Phase 7) -->
        <!-- Uncomment when Firebase is integrated
        <service
            android:name=".services.KaChatFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->

    </application>

</manifest>
